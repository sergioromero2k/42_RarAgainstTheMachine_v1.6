        <mxCell id="jVwDXL3oElWtDjvvyD6b-71" parent="jVwDXL3oElWtDjvvyD6b-70" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;fontSize=12;verticalAlign=top;resizable=0;rotatable=0;part=1;html=1;whiteSpace=wrap;" value="&lt;br&gt;&lt;div&gt;AST significa &lt;strong data-start=&quot;258&quot; data-end=&quot;289&quot;&gt;Árbol de Sintaxis Abstracta&lt;/strong&gt;.&lt;/div&gt;&lt;div&gt;* Verificar si es un .py largo o corto.&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;p data-start=&quot;0&quot; data-end=&quot;136&quot; class=&quot;PDq2pG_selectionAnchorContainer&quot;&gt;&lt;span aria-hidden=&quot;true&quot; class=&quot;PDq2pG_selectionAnchor&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;br&gt;&lt;p data-start=&quot;138&quot; data-end=&quot;287&quot;&gt;&lt;/p&gt;" vertex="1">
