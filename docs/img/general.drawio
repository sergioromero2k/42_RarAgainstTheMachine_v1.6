        <mxCell id="jVwDXL3oElWtDjvvyD6b-74" parent="jVwDXL3oElWtDjvvyD6b-73" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;strokeColor=default;align=center;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;AST para código-Python&lt;/h1&gt;&lt;div&gt;Árbol de Sintaxis Abstracta, cuando python lee un archivo .py, no piensa en texto, sino en una estructura jeráraquica.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;No ve caracteres; ve &lt;/span&gt;&lt;strong data-start=&quot;727&quot; data-end=&quot;761&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;funciones, clases y sentencias&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;p data-start=&quot;706&quot; data-end=&quot;762&quot; class=&quot;PDq2pG_selectionAnchorContainer&quot;&gt;&lt;span aria-hidden=&quot;true&quot; class=&quot;PDq2pG_selectionAnchor&quot;&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
