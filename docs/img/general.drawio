        <mxCell id="Nr13k9SWs_nuQRvrMUa1-74" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="200" width="330" x="680" y="240" as="geometry" />
        </mxCell>
        <mxCell id="Nr13k9SWs_nuQRvrMUa1-69" parent="Nr13k9SWs_nuQRvrMUa1-74" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;strokeColor=default;align=center;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Comandos CLI&lt;/h1&gt;&lt;p&gt;Tu programa, cuando lo ejecutes desde la terminal, tiene que aceptar comandos así.&lt;/p&gt;&lt;p&gt;python main.py index&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;python main.py search &quot;pregunta&quot;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;python main.py answer &quot;pregunta&quot;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;python main.py evaluate ...............&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="330" as="geometry" />
        </mxCell>
        <mxCell id="Nr13k9SWs_nuQRvrMUa1-70" parent="Nr13k9SWs_nuQRvrMUa1-74" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Cada&amp;nbsp; comando es uno de los pasos del pipeline, no puedes saltarte pasos del pipeline, porque generaría error." vertex="1">
          <mxGeometry height="30" width="320" y="170" as="geometry" />
        </mxCell>
        <mxCell id="Nr13k9SWs_nuQRvrMUa1-75" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="¿BM25?&lt;div&gt;Buscador&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="-500" y="160" as="geometry" />
        </mxCell>
        <mxCell id="fXpUvW09PbhyZoshMWz1-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;strokeColor=default;align=center;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;BaseModel&lt;/h1&gt;&lt;div&gt;Es una libreria que viene de pydantic. Cuando tu creas una clase que hereda de ella, consigues automáticamente. Validación y conversión/desde JSON. Sin Pydatinc, una clase normal de Python no comprueba nada, pueedes meterle cualquier tipo de dato en cualquier campo y no se queja.&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="290" x="1070" y="250" as="geometry" />
        </mxCell>
        <mxCell id="fXpUvW09PbhyZoshMWz1-2" edge="1" parent="1" source="Nr13k9SWs_nuQRvrMUa1-69" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="fXpUvW09PbhyZoshMWz1-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="1060" y="520" as="sourcePoint" />
            <mxPoint x="1110" y="470" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="fXpUvW09PbhyZoshMWz1-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;strokeColor=default;align=left;" value="&lt;b&gt;Antes de buscar: &lt;/b&gt;tienes preguntas &quot;puras&quot;, sin respuesta todavía.&amp;nbsp;&lt;div&gt;&lt;b&gt;Justo después de buscar:&lt;/b&gt; tienes preguntas + fragmentos encontrados, pero sin respuesta generada.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Después de responder:&lt;/b&gt; tienes preguntas + fragmentos + respuesta del LLM.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Al evaluar: &lt;/b&gt;comparas lo que generaste tú contra &quot;la solución correcta&quot; que te dan los profesores.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="300" x="230" y="720" as="geometry" />
