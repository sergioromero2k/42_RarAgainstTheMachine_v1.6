        <mxCell id="LQwCk8dbOmhS_KGoKl8P-22" parent="1" style="shape=note;size=20;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;&quot;&gt;El contenedor que agrupa muchas preguntas de golpe. Ocurre cuando cargas un archivo JSON entero(que tiene 100 preguntas dentro, por ejm). Acepta 2 con solucion y sin.&lt;/div&gt;" vertex="1">
